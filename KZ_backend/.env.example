# ============================================================
# Knowledge Zakat — Backend environment template
# Copy this file to `.env` and fill in real values.
# Never commit `.env` itself (add it to .gitignore).
# ============================================================

# Postgres connection string. Replace the placeholder password.
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost/knowledgeZakat

# JWT signing key. Generate a long random key with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# This MUST be kept secret. Anyone who knows it can forge admin tokens.
JWT_SECRET_KEY=replace_me_with_a_64_char_random_string_generated_locally
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of origins allowed to talk to the API.
# These are the only sites the browser will let send credentials.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Upload limits (5 MB default).
MAX_UPLOAD_SIZE_BYTES=5242880

# Set to "true" only when you actively want SQL traces in the console.
SQL_ECHO=false
